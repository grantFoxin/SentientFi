# ==================================================
# STELLAR PORTFOLIO REBALANCER - DOCKER DEPLOYMENT
# ==================================================

# PostgreSQL Configuration
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=portfolio_pass
POSTGRES_DB=stellar_portfolio

# Application Environment
NODE_ENV=development

# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ADDRESS=CCQ4LISQJFTZJKQDRJHRLXQ2UML45GVXUECN5NGSQKAT55JKAK2JAX7I
REFLECTOR_ADDRESS=

# Feature Flags
ENABLE_AUTO_REBALANCER=false
DEMO_MODE=true
ALLOW_DEMO_BALANCE_FALLBACK=true
ALLOW_FALLBACK_PRICES=true
ENABLE_DEBUG_ROUTES=false

# Notes:
# 1. Copy this file to .env before running: cp .env.example .env
# 2. Update CONTRACT_ADDRESS with your deployed Soroban contract
# 3. For production: Change passwords, set DEMO_MODE=false, NODE_ENV=production
